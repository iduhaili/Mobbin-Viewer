{
  "manifest_version": 3,
  "name": "Mobbin 查看器",
  "description": "为 Mobbin 提供去模糊、全屏查看、复制素材和批量下载功能。",
  "version": "0.0.6",
  "icons": {
    "32": "mobbin-helper-icon-32.png",
    "72": "mobbin-helper-icon-72.png",
    "128": "mobbin-helper-icon-128.png",
    "512": "mobbin-helper-icon-512.png"
  },
  "action": {
    "default_title": "Mobbin 查看器",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "mobbin-helper-icon-32.png",
      "72": "mobbin-helper-icon-72.png",
      "128": "mobbin-helper-icon-128.png",
      "512": "mobbin-helper-icon-512.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "tabs", "downloads"],
  "host_permissions": ["https://mobbin.com/*", "https://*.mobbin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mobbin.com/*", "https://*.mobbin.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
